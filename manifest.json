{
  "manifest_version": 3,
  "name": "Attendance Tracker",
  "version": "1.0",
  "description": "Shows how many classes to attend or skip to hit 85% attendance",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["https://espro.christuniversity.in:444/*"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
